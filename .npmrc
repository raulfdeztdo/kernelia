auto-install-peers=true
strict-peer-dependencies=false
# In pnpm 10.x install fails (exit 1) when transitive deps have build scripts
# that are not in the onlyBuiltDependencies allowlist. We *do* allow esbuild /
# sharp / unrs-resolver (via package.json#pnpm and pnpm-workspace.yaml), but
# Vercel's build image runs an older pnpm that reads the allowlist from only
# one of those locations. Disabling strict mode lets install succeed even if
# the allowlist isn't picked up; the listed packages still get their scripts
# run wherever the allowlist *is* honored.
strict-dep-builds=false

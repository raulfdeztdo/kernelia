# ─── Supabase Postgres ────────────────────────────────────────────────
# Settings -> Database -> Connection string -> "URI" (con session pooler)
DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Para drizzle-kit migrate (conexion directa, no pooler)
DATABASE_URL_DIRECT=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Para uso desde el cliente si llega a hacer falta (lectura publica)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo server-side. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE=

# ─── Cerebras (LLM) ────────────────────────────────────────────────────
# https://cloud.cerebras.ai/ -> API Keys
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.1-8b

# Fallback opcional (Groq, Gemini, OpenRouter)
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_MODEL=

# ─── Cron ──────────────────────────────────────────────────────────────
# Header Authorization: Bearer <CRON_SECRET> requerido en /api/cron/*
CRON_SECRET=

# ─── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Origen publico (sin slash final). Lo usan metadata, sitemap, robots y RSS.
# En Vercel se rellena con tu dominio (https://kernelia.app, etc).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# ─── Admin backoffice (Fase 7) ─────────────────────────────────────────
# Email del primer admin. Se siembra solo si la tabla users esta vacia
# (idempotente). En produccion debe ser el email del operador humano.
INITIAL_ADMIN_EMAIL=

# Secreto para firmar la cookie de sesion (HMAC-SHA256).
# Generar con: openssl rand -hex 32
# Minimo 32 caracteres; fail-fast en boot si falta o es mas corto.
SESSION_SECRET=

# Resend — envia los magic-links de login.
# Crear en https://resend.com -> API Keys.
RESEND_API_KEY=
# Remitente. Hasta verificar el dominio kernelia.dev en Resend (SPF+DKIM),
# se puede usar "Kernelia <onboarding@resend.dev>" pero solo entrega al
# email de la cuenta de Resend. En produccion: "Kernelia <admin@kernelia.dev>".
EMAIL_FROM=
